# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Podcast Index  — https://api.podcastindex.org/signup  (topic frequency)
PI_KEY=
PI_SECRET=

# Listen Notes   — https://www.listennotes.com/api/    (audience proxy)
LISTEN_API_KEY=

# Optional. A contact string sent as User-Agent (Podcast Index asks for one).
USER_AGENT=podcastranker/0.1 (+https://github.com/edmfg/podcastranker)
