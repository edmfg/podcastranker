# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Podcast Index  — https://api.podcastindex.org/signup  (topic frequency) — REQUIRED
# You get the key + secret together when you create a key. The secret is shown
# only once (at creation); if you lost it, delete the key and make a new one.
PI_KEY=
PI_SECRET=

# Listen Notes   — https://www.listennotes.com/api/    (audience proxy) — OPTIONAL
# If left blank, the ranker uses a KEYLESS Apple Top Chart audience proxy instead.
LISTEN_API_KEY=

# Optional. A contact string sent as User-Agent (Podcast Index asks for one).
USER_AGENT=podcastranker/0.1 (+https://github.com/edmfg/podcastranker)
